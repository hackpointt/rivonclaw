{
  "id": "rivonclaw-policy",
  "name": "RivonClaw Policy",
  "description": "Injects compiled policies and guard directives into the agent system prompt",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "compiledPolicy": {
        "type": "string",
        "description": "Concatenated compiled policy fragments"
      },
      "guards": {
        "type": "array",
        "description": "Active guard directives",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "ruleId": { "type": "string" },
            "content": { "type": "string" }
          }
        }
      }
    }
  }
}
