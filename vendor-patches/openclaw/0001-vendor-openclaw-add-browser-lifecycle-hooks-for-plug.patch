 };
 
+// Browser context (shared across browser hooks)
+export type PluginHookBrowserContext = {
+  sessionKey?: string;
+  profile?: string;
+};
+
+// browser_session_start hook
+export type PluginHookBrowserSessionStartEvent = {
+  profile?: string;
+  action: "start";
+};
+
+// browser_session_end hook
+export type PluginHookBrowserSessionEndEvent = {
+  profile?: string;
+  action: "stop";
+};
+
+// before_browser_action hook
+export type PluginHookBeforeBrowserActionEvent = {
+  action: string;
+  params: Record<string, unknown>;
+  profile?: string;
+};
+
+export type PluginHookBeforeBrowserActionResult = {
+  params?: Record<string, unknown>;
+  block?: boolean;
+  blockReason?: string;
+};
+
+// after_browser_action hook
+export type PluginHookAfterBrowserActionEvent = {
+  action: string;
+  params: Record<string, unknown>;
+  profile?: string;
+  result?: unknown;
+  error?: string;
+  durationMs?: number;
+};
+
 // Hook handler types mapped by hook name
 export type PluginHookHandlerMap = {
   before_model_resolve: (
@@ -881,6 +930,22 @@ export type PluginHookHandlerMap = {
     event: PluginHookGatewayStopEvent,
     ctx: PluginHookGatewayContext,
   ) => Promise<void> | void;
+  browser_session_start: (
+    event: PluginHookBrowserSessionStartEvent,
+    ctx: PluginHookBrowserContext,
+  ) => Promise<void> | void;
+  browser_session_end: (
+    event: PluginHookBrowserSessionEndEvent,
+    ctx: PluginHookBrowserContext,
+  ) => Promise<void> | void;
+  before_browser_action: (
+    event: PluginHookBeforeBrowserActionEvent,
+    ctx: PluginHookBrowserContext,
+  ) => Promise<PluginHookBeforeBrowserActionResult | void> | PluginHookBeforeBrowserActionResult | void;
+  after_browser_action: (
+    event: PluginHookAfterBrowserActionEvent,
+    ctx: PluginHookBrowserContext,
+  ) => Promise<void> | void;
 };
 
