From ad86140e180e731056c81bd897ed8f183de0b418 Mon Sep 17 00:00:00 2001
From: Gaoyang Zhang <younglobalization@gmail.com>
Date: Sun, 15 Mar 2026 13:04:09 -0700
Subject: [PATCH] vendor(openclaw): add browser lifecycle hooks for plugin
 integration

Why:
- EasyClaw needs to track browser session lifecycle (start/stop) to
  persist session state (cookies) across restarts
- EasyClaw needs before/after action hooks for future extensibility
  (auth injection, captcha solving, page preparation)
- Existing before_tool_call/after_tool_call hooks lack browser-specific
  context and proper timing semantics

Removal:
- When OpenClaw adds native browser lifecycle hooks upstream
- Track: propose as upstream PR after proving the design in EasyClaw

Tests:
- extensions/browser-profiles-tools/src/browser-lifecycle-hooks.test.ts
---
 src/agents/tools/browser-tool.ts | 64 +++++++++++++++++++++++++++
 src/plugins/hooks.ts             | 74 ++++++++++++++++++++++++++++++++
 src/plugins/types.ts             | 67 ++++++++++++++++++++++++++++-
 3 files changed, 204 insertions(+), 1 deletion(-)

diff --git a/src/agents/tools/browser-tool.ts b/src/agents/tools/browser-tool.ts
index 80faf99a1..7d2413805 100644
--- a/src/agents/tools/browser-tool.ts
+++ b/src/agents/tools/browser-tool.ts
@@ -24,6 +24,7 @@ import {
   untrackSessionBrowserTab,
 } from "../../browser/session-tab-registry.js";
 import { loadConfig } from "../../config/config.js";
+import { getGlobalHookRunner } from "../../plugins/hook-runner-global.js";
 import {
   executeActAction,
   executeConsoleAction,
@@ -355,6 +356,35 @@ export function createBrowserTool(opts?: {
           }
         : null;
 
+      // --- Browser lifecycle hooks (EasyClaw patch) ---
+      const hookRunner = getGlobalHookRunner();
+      const browserHookCtx = { sessionKey: opts?.agentSessionKey, profile };
+
+      // before_browser_action: let plugins inspect/modify/block non-lifecycle actions
+      if (
+        hookRunner?.hasHooks("before_browser_action") &&
+        action !== "start" &&
+        action !== "stop" &&
+        action !== "status" &&
+        action !== "profiles"
+      ) {
+        const beforeResult = await hookRunner.runBeforeBrowserAction(
+          { action, params, profile },
+          browserHookCtx,
+        );
+        if (beforeResult?.block) {
+          throw new Error(beforeResult.blockReason ?? "Browser action blocked by plugin");
+        }
+        if (beforeResult?.params) {
+          Object.assign(params, beforeResult.params);
+        }
+      }
+
+      // Wrap the action switch in try/finally so after_browser_action fires uniformly
+      const actionStartTime = Date.now();
+      let actionError: string | undefined;
+      try {
+        const actionResult = await (async () => {
       switch (action) {
         case "status":
           if (proxyRequest) {
@@ -652,6 +682,40 @@ export function createBrowserTool(opts?: {
         default:
           throw new Error(`Unknown action: ${action}`);
       }
+        })();
+
+        // browser_session_start: fires after successful browser start
+        if (action === "start" && hookRunner?.hasHooks("browser_session_start")) {
+          void hookRunner.runBrowserSessionStart({ profile, action: "start" }, browserHookCtx);
+        }
+        // browser_session_end: fires after successful browser stop
+        if (action === "stop" && hookRunner?.hasHooks("browser_session_end")) {
+          void hookRunner.runBrowserSessionEnd({ profile, action: "stop" }, browserHookCtx);
+        }
+
+        return actionResult;
+      } catch (err) {
+        actionError = String(err);
+        throw err;
+      } finally {
+        // after_browser_action: fires for all non-metadata actions
+        if (
+          hookRunner?.hasHooks("after_browser_action") &&
+          action !== "status" &&
+          action !== "profiles"
+        ) {
+          void hookRunner.runAfterBrowserAction(
+            {
+              action,
+              params,
+              profile,
+              error: actionError,
+              durationMs: Date.now() - actionStartTime,
+            },
+            browserHookCtx,
+          );
+        }
+      }
     },
   };
 }
diff --git a/src/plugins/hooks.ts b/src/plugins/hooks.ts
index 4d74267d4..110d717d7 100644
--- a/src/plugins/hooks.ts
+++ b/src/plugins/hooks.ts
@@ -50,6 +50,12 @@ import type {
   PluginHookToolResultPersistResult,
   PluginHookBeforeMessageWriteEvent,
   PluginHookBeforeMessageWriteResult,
+  PluginHookBrowserContext,
+  PluginHookBrowserSessionStartEvent,
+  PluginHookBrowserSessionEndEvent,
+  PluginHookBeforeBrowserActionEvent,
+  PluginHookBeforeBrowserActionResult,
+  PluginHookAfterBrowserActionEvent,
 } from "./types.js";
 
 // Re-export types for consumers
@@ -171,6 +177,15 @@ export function createHookRunner(registry: PluginRegistry, options: HookRunnerOp
     };
   };
 
+  const mergeBeforeBrowserAction = (
+    acc: PluginHookBeforeBrowserActionResult | undefined,
+    next: PluginHookBeforeBrowserActionResult,
+  ): PluginHookBeforeBrowserActionResult => ({
+    params: next.params ?? acc?.params,
+    block: acc?.block || next.block,
+    blockReason: acc?.blockReason ?? next.blockReason,
+  });
+
   const mergeSubagentDeliveryTargetResult = (
     acc: PluginHookSubagentDeliveryTargetResult | undefined,
     next: PluginHookSubagentDeliveryTargetResult,
@@ -704,6 +719,60 @@ export function createHookRunner(registry: PluginRegistry, options: HookRunnerOp
     return runVoidHook("gateway_stop", event, ctx);
   }
 
+  // =========================================================================
+  // Browser Hooks
+  // =========================================================================
+
+  /**
+   * Run browser_session_start hook.
+   * Runs in parallel (fire-and-forget).
+   */
+  async function runBrowserSessionStart(
+    event: PluginHookBrowserSessionStartEvent,
+    ctx: PluginHookBrowserContext,
+  ): Promise<void> {
+    await runVoidHook("browser_session_start", event, ctx);
+  }
+
+  /**
+   * Run browser_session_end hook.
+   * Runs in parallel (fire-and-forget).
+   */
+  async function runBrowserSessionEnd(
+    event: PluginHookBrowserSessionEndEvent,
+    ctx: PluginHookBrowserContext,
+  ): Promise<void> {
+    await runVoidHook("browser_session_end", event, ctx);
+  }
+
+  /**
+   * Run before_browser_action hook.
+   * Allows plugins to modify or block browser actions.
+   * Runs sequentially.
+   */
+  async function runBeforeBrowserAction(
+    event: PluginHookBeforeBrowserActionEvent,
+    ctx: PluginHookBrowserContext,
+  ): Promise<PluginHookBeforeBrowserActionResult | undefined> {
+    return runModifyingHook<"before_browser_action", PluginHookBeforeBrowserActionResult>(
+      "before_browser_action",
+      event,
+      ctx,
+      mergeBeforeBrowserAction,
+    );
+  }
+
+  /**
+   * Run after_browser_action hook.
+   * Runs in parallel (fire-and-forget).
+   */
+  async function runAfterBrowserAction(
+    event: PluginHookAfterBrowserActionEvent,
+    ctx: PluginHookBrowserContext,
+  ): Promise<void> {
+    await runVoidHook("after_browser_action", event, ctx);
+  }
+
   // =========================================================================
   // Utility
   // =========================================================================
@@ -753,6 +822,11 @@ export function createHookRunner(registry: PluginRegistry, options: HookRunnerOp
     // Gateway hooks
     runGatewayStart,
     runGatewayStop,
+    // Browser hooks
+    runBrowserSessionStart,
+    runBrowserSessionEnd,
+    runBeforeBrowserAction,
+    runAfterBrowserAction,
     // Utility
     hasHooks,
     getHookCount,
